{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Working-Capital Credit Scorecard for Merchants\n",
    "## Exploratory Data Analysis & Scorecard Validation\n",
    "\n",
    "**Author:** Kasturi Dash\n",
    "**Date:** July 2026\n",
    "\n",
    "This notebook validates the credit scorecard methodology, analyzes risk distributions,\n",
    "and prepares data for the interactive dashboard."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "sns.set_palette('husl')\n",
    "\n",
    "print('Libraries loaded')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('../data/merchants.csv')\n",
    "print(f'Merchants: {len(df)}')\n",
    "print(f'Categories: {df["category"].nunique()}')\n",
    "print(f'Columns: {df.columns.tolist()}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Distribution Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n",
    "\n",
    "# Monthly volume\n",
    "axes[0,0].hist(df['monthly_volume_lakhs'], bins=30, color='steelblue', edgecolor='white')\n",
    "axes[0,0].set_title('Monthly Volume Distribution')\n",
    "axes[0,0].set_xlabel('Volume (₹L)')\n",
    "\n",
    "# DSCR\n",
    "axes[0,1].hist(df['dscr'], bins=30, color='coral', edgecolor='white')\n",
    "axes[0,1].set_title('DSCR Distribution')\n",
    "axes[0,1].set_xlabel('DSCR (x)')\n",
    "\n",
    "# Refund ratio\n",
    "axes[0,2].hist(df['refund_ratio'], bins=30, color='mediumseagreen', edgecolor='white')\n",
    "axes[0,2].set_title('Refund Ratio Distribution')\n",
    "axes[0,2].set_xlabel('Refund Ratio')\n",
    "\n",
    "# Chargeback ratio\n",
    "axes[1,0].hist(df['chargeback_ratio'], bins=30, color='gold', edgecolor='white')\n",
    "axes[1,0].set_title('Chargeback Ratio Distribution')\n",
    "axes[1,0].set_xlabel('Chargeback Ratio')\n",
    "\n",
    "# Vintage\n",
    "axes[1,1].hist(df['vintage_months'], bins=20, color='mediumpurple', edgecolor='white')\n",
    "axes[1,1].set_title('Business Vintage Distribution')\n",
    "axes[1,1].set_xlabel('Months on Platform')\n",
    "\n",
    "# Seasonality\n",
    "axes[1,2].hist(df['seasonality_index'], bins=30, color='teal', edgecolor='white')\n",
    "axes[1,2].set_title('Seasonality Index Distribution')\n",
    "axes[1,2].set_xlabel('Seasonality Index')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Category Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cat_summary = df.groupby('category').agg({\n",
    "    'merchant_id': 'count',\n",
    "    'monthly_volume_lakhs': 'mean',\n",
    "    'refund_ratio': 'mean',\n",
    "    'chargeback_ratio': 'mean',\n",
    "    'dscr': 'mean',\n",
    "    'seasonality_index': 'mean'\n",
    "}).round(3)\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# Volume by category\n",
    "cat_summary.sort_values('monthly_volume_lakhs', ascending=True)['monthly_volume_lakhs'].plot(kind='barh', ax=axes[0,0], color='steelblue')\n",
    "axes[0,0].set_title('Avg Monthly Volume by Category')\n",
    "\n",
    "# Refund ratio by category\n",
    "cat_summary.sort_values('refund_ratio', ascending=True)['refund_ratio'].plot(kind='barh', ax=axes[0,1], color='coral')\n",
    "axes[0,1].set_title('Avg Refund Ratio by Category')\n",
    "\n",
    "# Chargeback ratio by category\n",
    "cat_summary.sort_values('chargeback_ratio', ascending=True)['chargeback_ratio'].plot(kind='barh', ax=axes[1,0], color='gold')\n",
    "axes[1,0].set_title('Avg Chargeback Ratio by Category')\n",
    "\n",
    "# DSCR by category\n",
    "cat_summary.sort_values('dscr', ascending=True)['dscr'].plot(kind='barh', ax=axes[1,1], color='mediumseagreen')\n",
    "axes[1,1].set_title('Avg DSCR by Category')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Risk Scorecard Validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run scorecard engine\n",
    "import sys\n",
    "sys.path.append('../engine')\n",
    "from scorecard_engine import CreditScorecardPipeline\n",
    "\n",
    "pipeline = CreditScorecardPipeline(df)\n",
    "results = pipeline.run()\n",
    "\n",
    "print('Scorecard Results:')\n",
    "print(results[['merchant_id', 'risk_score', 'risk_grade', 'credit_limit_lakhs', 'recommendation']].head(10).to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Results Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "# Risk score distribution\n",
    "axes[0,0].hist(results['risk_score'], bins=25, color='steelblue', edgecolor='white')\n",
    "axes[0,0].set_title('Risk Score Distribution')\n",
    "axes[0,0].axvline(results['risk_score'].mean(), color='red', linestyle='--', label=f'Mean: {results["risk_score"].mean():.1f}')\n",
    "axes[0,0].legend()\n",
    "\n",
    "# Grade distribution\n",
    "grade_counts = results['risk_grade'].value_counts().sort_index()\n",
    "axes[0,1].bar(grade_counts.index, grade_counts.values, color=['#22c55e', '#3b82f6', '#f59e0b', '#ef4444'])\n",
    "axes[0,1].set_title('Risk Grade Distribution')\n",
    "\n",
    "# Credit limit by grade\n",
    "results.boxplot(column='credit_limit_lakhs', by='risk_grade', ax=axes[1,0])\n",
    "axes[1,0].set_title('Credit Limit by Risk Grade')\n",
    "axes[1,0].set_xlabel('Risk Grade')\n",
    "\n",
    "# Recommendation distribution\n",
    "rec_counts = results['recommendation'].value_counts()\n",
    "axes[1,1].barh(rec_counts.index, rec_counts.values, color=['#22c55e', '#3b82f6', '#f59e0b', '#ef4444'])\n",
    "axes[1,1].set_title('Approval Recommendation Distribution')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Correlation Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "corr_cols = ['monthly_volume_lakhs', 'refund_ratio', 'chargeback_ratio', \n",
    "             'settlement_score', 'dscr', 'vintage_months', 'risk_score', 'credit_limit_lakhs']\n",
    "corr = results[corr_cols].corr()\n",
    "\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(corr, annot=True, cmap='RdYlGn', center=0, fmt='.2f')\n",
    "plt.title('Feature Correlation Matrix')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Summary\n",
    "\n",
    "This analysis validates:\n",
    "1. **Realistic distributions** across all merchant attributes\n",
    "2. **Risk-score differentiation** — grades A-D show clear separation\n",
    "3. **Credit limit correlation** with risk grade and volume\n",
    "4. **Approval recommendation logic** — conservative for high-risk, generous for low-risk\n",
    "\n",
    "The interactive dashboard at `../index.html` presents these results for stakeholder review."
   ]
  }
 ],
